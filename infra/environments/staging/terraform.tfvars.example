# ==============================================================
# Example Terraform Variables — Staging Environment
# ==============================================================
# Copy to `terraform.tfvars` and fill in your values.
# DO NOT commit the real terraform.tfvars (it holds secrets).
#
# Required: project_id + the three secrets. Everything else has a
# sensible staging default (shown below) — uncomment to override.

# ---- GCP Context ----
project_id  = "YOUR_GCP_PROJECT_ID"
region      = "us-central1"
zone        = "us-central1-a"
environment = "staging"

# ---- Cluster ----
cluster_name = "jerney-gke-staging"

# Node pool (optional — staging defaults shown)
# node_machine_type   = "e2-medium"
# min_node_count      = 1
# max_node_count      = 4
# disk_size_gb        = 30
# use_spot            = false         # on-demand — steadier than dev
# deletion_protection = false

# ---- Networking (optional — defaults shown) ----
# subnet_cidr   = "10.0.0.0/24"
# pods_cidr     = "10.100.0.0/14"
# services_cidr = "10.104.0.0/20"

# ---- GitOps ----
gitops_repo_url        = "https://github.com/NilkanthMiyani/gke-jerney.git"
gitops_target_revision = "main"
gitops_apps_path       = "k8s-gke/apps"

# ---- Secrets (seeded into GCP Secret Manager) ----
# Replace with strong, unique values for this environment.
postgres_password      = "replace-with-staging-postgres-password"
grafana_admin_password = "replace-with-staging-grafana-password"
alertmanager_smtp_key  = "re_replace_with_resend_api_key"
